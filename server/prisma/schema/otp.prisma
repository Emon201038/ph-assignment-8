model OTP {
  id        String   @id @default(uuid())
  type      OTPType
  userId    String
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum OTPType {
  TWO_FACTOR
  PASSWORD_RESET
  AUTH_VERIFICATION
}
