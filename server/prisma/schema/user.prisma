model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(TRAVELER)

  avatar  String?
  bio     String?
  phone   String?
  country String?

  createdTours Tour[] @relation("TourCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  TRAVELER
  GUIDE
  ADMIN
}
