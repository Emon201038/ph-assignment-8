{
  "compilerOptions": {
    "target": "es2016",                   /* JS version for emitted code */
    "module": "commonjs",                 /* CommonJS for Node */
    "rootDirs": ["src", "prisma"],        /* Treat src and prisma as one logical root */
    "outDir": "./dist",                   /* Output folder for compiled JS */
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src", 
    "prisma", 
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}